{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "dev",
            "displayName": "Development",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/dev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_STANDARD": "20",
                "HBRICK_WARNINGS_AS_ERRORS": "ON"
            }
        },
        {
            "name": "dev-full",
            "inherits": "dev",
            "displayName": "Development (full MovingAI tests)",
            "cacheVariables": {
                "HBRICK_FULL_MOVINGAI_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "dev"
        },
        {
            "name": "dev-full",
            "configurePreset": "dev-full"
        }
    ],
    "testPresets": [
        {
            "name": "dev",
            "configurePreset": "dev",
            "execution": {
                "jobs": 0
            },
            "output": {
                "outputOnFailure": true,
                "shortProgress": true,
                "verbosity": "verbose"
            }
        },
        {
            "name": "dev-fast",
            "configurePreset": "dev",
            "filter": {
                "exclude": {
                    "label": "slow"
                }
            },
            "execution": {
                "jobs": 0
            },
            "output": {
                "outputOnFailure": true,
                "shortProgress": true
            }
        },
        {
            "name": "dev-full",
            "configurePreset": "dev-full",
            "execution": {
                "jobs": 0
            },
            "output": {
                "outputOnFailure": true,
                "shortProgress": true,
                "verbosity": "verbose"
            }
        }
    ]
}
