# Doxyfile for hbrick — generated by CMake from docs/Doxyfile.in.
# Reconfigure after changing HBRICK_DOCS_* cache variables in CMakeLists.txt.

PROJECT_NAME           = "@PROJECT_NAME@"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
PROJECT_BRIEF          = "Graph reachability library for directed graphs and grid mazes"

OUTPUT_DIRECTORY       = @HBRICK_DOCS_OUTPUT_DIR@
CREATE_SUBDIRS         = NO

INPUT                  = @HBRICK_DOXYGEN_INPUT_DIRS@ \
                         @CMAKE_SOURCE_DIR@/docs/mainpage.md \
                         @CMAKE_SOURCE_DIR@/docs/groups.dox
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.hpp *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = @CMAKE_SOURCE_DIR@/docs/mainpage.md

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_FRIEND_COMPOUNDS  = NO
INTERNAL_DOCS          = NO
SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
GENERATE_TREEVIEW      = @HBRICK_DOCS_GENERATE_TREEVIEW_DOXY@

QUIET                  = @HBRICK_DOCS_QUIET_DOXY@
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = @HBRICK_DOCS_WARN_IF_UNDOCUMENTED_DOXY@
WARN_IF_DOC_ERROR      = @HBRICK_DOCS_WARN_IF_DOC_ERROR_DOXY@
WARN_NO_PARAMDOC       = @HBRICK_DOCS_WARN_NO_PARAMDOC_DOXY@

MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO

OPTIMIZE_OUTPUT_FOR_C  = NO
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
TAB_SIZE               = 4
ALIASES                =

ENABLED_SECTIONS       =
GENERATE_HTML          = YES
HTML_OUTPUT            = @HBRICK_DOCS_HTML_SUBDIR@
HTML_DYNAMIC_MENUS     = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO

HAVE_DOT               = NO
